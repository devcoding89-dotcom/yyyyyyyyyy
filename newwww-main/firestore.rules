
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * EMAILCRAFT STUDIO SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict "User-Ownership" model. EmailCraft Studio is designed so 
     * that every piece of data—from contacts to campaign logs—is private and belongs 
     * exclusively to the authenticated user who created it.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      /** User Profile rules. */
      allow get, create, update, delete: if isOwner(userId);
      allow list: if isOwner(userId);

      /** Nested resources - all follow the same ownership pattern. */
      match /parses/{parseId} {
        allow read, write: if isOwner(userId);
      }
      
      match /templates/{templateId} {
        allow read, write: if isOwner(userId);
      }

      match /contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }

      match /contactLists/{contactListId} {
        allow read, write: if isOwner(userId);
      }

      match /campaigns/{campaignId} {
        allow read, write: if isOwner(userId);

        match /logs/{logId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
  }
}
